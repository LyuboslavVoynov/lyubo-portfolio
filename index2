<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lyubo Voynov · Operational AI Architect</title>
<meta name="description" content="I turn operational chaos into intelligent systems — AI agents, automation and data architecture that save six figures, lift customer outcomes and scale decision-making.">

<link rel="icon" type="image/png" href="logo.png">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
<style>
/* ─── RESET ─── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

/* ─── TOKENS (from original) ─── */
:root{
  --navy:#1B2A4A; --navy-dark:#0F1E38; --navy-mid:#223358; --navy-light:#2A3F6B;
  --navy-pale:#EEF2F8;
  --accent:#2563EB; --accent-dark:#1D4ED8; --accent-soft:#93C5FD;
  --white:#FFFFFF; --off-white:#F7F9FC;
  --text-dark:#1B2A4A; --text-body:#3D4F6B; --text-muted:#7A8FAD;
  --border-light:rgba(27,42,74,0.1);
  --green:#16A34A; --green-soft:#DCFCE7; --amber:#D97706; --amber-soft:#FEF3C7;
  --shadow-sm:0 2px 12px rgba(27,42,74,0.08);
  --shadow-md:0 8px 32px rgba(27,42,74,0.12);
  --shadow-lg:0 24px 64px rgba(27,42,74,0.16);
}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--text-dark);overflow-x:hidden;line-height:1.6;-webkit-font-smoothing:antialiased;}

/* ─── UTILS ─── */
.inner{max-width:1140px;margin:0 auto;padding:0 24px;}
.section-label{font-size:.72rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:inline-block;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3.5vw,2.8rem);font-weight:600;letter-spacing:-.02em;line-height:1.15;color:var(--navy-dark);}
.section-desc{color:var(--text-body);font-size:1rem;font-weight:300;line-height:1.75;max-width:560px;margin-top:14px;}
.block{padding:96px 0;border-top:1px solid var(--border-light);}
.block.light{background:var(--off-white);}
.block.dark{background:var(--navy-dark);border-top:none;}
.block.dark .section-title{color:var(--white);}
.block.dark .section-label{color:var(--accent-soft);}
.block.dark .section-desc{color:rgba(255,255,255,.6);}
.section-head{margin-bottom:52px;}

/* ─── NAV ─── */
nav{position:fixed;top:0;left:0;right:0;z-index:600;background:rgba(255,255,255,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--border-light);height:68px;display:flex;align-items:center;transition:box-shadow .3s;}
nav.scrolled{box-shadow:var(--shadow-md);}
.nav-inner{width:100%;max-width:1140px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;color:var(--navy-dark);text-decoration:none;white-space:nowrap;}
.nav-logo span{color:var(--accent);}
.nav-links{display:flex;gap:32px;list-style:none;align-items:center;}
.nav-links a{color:var(--text-body);text-decoration:none;font-size:.88rem;font-weight:400;transition:color .2s;}
.nav-links a:hover{color:var(--navy-dark);}
.nav-cta{background:var(--accent) !important;color:var(--white) !important;padding:9px 20px;border-radius:100px;font-weight:500 !important;font-size:.88rem !important;display:inline-flex;align-items:center;gap:7px;box-shadow:0 4px 14px rgba(37,99,235,.3);transition:all .2s !important;}
.nav-cta:hover{background:var(--accent-dark) !important;transform:translateY(-1px);box-shadow:0 6px 20px rgba(37,99,235,.4) !important;}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;}
.hamburger span{display:block;width:24px;height:2px;background:var(--navy-dark);border-radius:2px;transition:.3s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-menu{display:none;position:fixed;top:68px;left:0;right:0;background:var(--white);border-bottom:1px solid var(--border-light);padding:18px 24px 26px;z-index:599;box-shadow:var(--shadow-md);}
.mobile-menu.open{display:block;}
.mobile-menu ul{list-style:none;}
.mobile-menu a{display:block;padding:12px 0;color:var(--text-body);text-decoration:none;font-size:1rem;border-bottom:1px solid var(--border-light);}
.mobile-menu .mob-cta{display:inline-flex;margin-top:16px;background:var(--accent);color:var(--white) !important;padding:12px 26px;border-radius:100px;font-weight:500;text-decoration:none;border-bottom:none !important;}

/* ─── BUTTONS ─── */
.btn{display:inline-flex;align-items:center;gap:8px;border-radius:100px;text-decoration:none;font-size:.95rem;font-weight:500;cursor:pointer;border:none;transition:all .25s ease;white-space:nowrap;}
.btn-primary{background:var(--accent);color:var(--white);padding:14px 28px;box-shadow:0 4px 20px rgba(37,99,235,.35);}
.btn-primary:hover{background:var(--accent-dark);transform:translateY(-2px);box-shadow:0 8px 28px rgba(37,99,235,.45);}
.btn-ghost{background:rgba(255,255,255,.1);color:var(--white);padding:14px 28px;border:1px solid rgba(255,255,255,.2);}
.btn-ghost:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.35);}
.arr{display:inline-block;transition:transform .2s;}
.btn:hover .arr{transform:translateX(3px);}

/* ─── HERO ─── */
.hero{min-height:100vh;padding-top:68px;background:linear-gradient(160deg,var(--navy-dark) 0%,var(--navy) 55%,var(--navy-mid) 100%);position:relative;overflow:hidden;display:flex;align-items:center;}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:56px 56px;}
.hero-glow{position:absolute;top:-20%;right:-10%;width:60vw;max-width:700px;height:70vh;background:radial-gradient(ellipse,rgba(37,99,235,.14) 0%,transparent 65%);pointer-events:none;}
.hero-inner{position:relative;z-index:2;width:100%;max-width:1140px;margin:0 auto;padding:80px 24px;display:grid;grid-template-columns:1fr 380px;gap:56px;align-items:center;}
.hero-left{min-width:0;}
.hero-photo-col{display:flex;justify-content:center;opacity:0;transform:translateY(24px);animation:up .8s ease .5s forwards;}
.hero-photo-frame{position:relative;width:100%;max-width:360px;}
.hero-photo-card{width:100%;aspect-ratio:3/4;border-radius:28px;overflow:hidden;position:relative;background:linear-gradient(135deg,var(--navy-light),rgba(37,99,235,.15));border:1px solid rgba(255,255,255,.14);box-shadow:0 32px 80px rgba(0,0,0,.4);}
.hero-photo-card img{width:100%;height:100%;object-fit:cover;display:block;}
.hero-photo-frame::after{content:'';position:absolute;inset:0;border-radius:28px;pointer-events:none;box-shadow:inset 0 0 0 1px rgba(147,197,253,.18);}
.hero-photo-badge{position:absolute;left:-14px;bottom:22px;display:inline-flex;align-items:center;gap:9px;background:rgba(15,30,56,.82);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(147,197,253,.25);border-radius:100px;padding:9px 16px 9px 12px;box-shadow:var(--shadow-md);}
.hero-photo-badge .dot{width:9px;height:9px;border-radius:50%;background:#34D399;box-shadow:0 0 0 4px rgba(52,211,153,.2);}
.hero-photo-badge span{font-size:.78rem;font-weight:500;color:#fff;white-space:nowrap;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:9px;font-size:.74rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--accent-soft);background:rgba(37,99,235,.12);border:1px solid rgba(147,197,253,.25);padding:7px 16px;border-radius:100px;opacity:0;transform:translateY(22px);animation:up .7s ease .2s forwards;}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.6rem,5.6vw,4.8rem);font-weight:600;line-height:1.06;letter-spacing:-.03em;color:var(--white);margin:24px 0 24px;max-width:16ch;opacity:0;transform:translateY(24px);animation:up .7s ease .32s forwards;}
.hero h1 em{font-style:italic;color:var(--accent-soft);}
.hero-sum{font-size:clamp(1rem,1.8vw,1.18rem);font-weight:300;color:rgba(255,255,255,.7);line-height:1.7;max-width:640px;opacity:0;transform:translateY(24px);animation:up .7s ease .44s forwards;}
.hero-sum b{color:var(--white);font-weight:500;}
.hero-actions{display:flex;gap:14px;align-items:center;flex-wrap:wrap;margin-top:38px;opacity:0;transform:translateY(24px);animation:up .7s ease .56s forwards;}
@keyframes up{to{opacity:1;transform:translateY(0);}}

/* ─── DASHBOARD ─── */
.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}
.dash-card{background:var(--white);border:1px solid var(--border-light);border-radius:18px;padding:26px 24px;box-shadow:var(--shadow-sm);transition:transform .25s,box-shadow .25s;}
.dash-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);}
.dash-card.feature{background:linear-gradient(150deg,var(--navy) 0%,var(--navy-mid) 100%);border-color:transparent;box-shadow:var(--shadow-md);position:relative;overflow:hidden;}
.dash-card.feature::before{content:'';position:absolute;top:-50px;right:-50px;width:180px;height:180px;background:radial-gradient(circle,rgba(37,99,235,.25),transparent 65%);pointer-events:none;}
.dash-val{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.4vw,2.6rem);font-weight:600;letter-spacing:-.02em;line-height:1;color:var(--navy-dark);}
.dash-val .ac{color:var(--accent);}
.dash-val sup{font-size:.5em;font-weight:600;top:-.7em;}
.dash-card.feature .dash-val{color:var(--white);}
.dash-card.feature .dash-val .ac{color:var(--accent-soft);}
.dash-lab{margin-top:12px;font-size:.84rem;color:var(--text-muted);font-weight:400;line-height:1.4;}
.dash-card.feature .dash-lab{color:rgba(255,255,255,.7);}

/* ─── HIRE CARDS ─── */
.hire-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.hire-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:32px 28px;transition:all .35s ease;display:flex;flex-direction:column;}
.hire-card:hover{border-color:rgba(37,99,235,.35);transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,.25);}
.hire-num{font-family:'Playfair Display',serif;font-size:2.4rem;font-weight:600;line-height:1;color:var(--accent-soft);}
.hire-card h3{font-size:1.04rem;font-weight:600;color:var(--white);margin:18px 0 10px;line-height:1.3;}
.hire-card p{font-size:.9rem;color:rgba(255,255,255,.6);line-height:1.7;font-weight:300;flex:1;}
.hire-tag{display:block;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,.08);font-size:.69rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(147,197,253,.8);}

/* ─── WHAT I BUILD (loop) ─── */
.build-wrap{background:var(--white);border:1px solid var(--border-light);border-radius:24px;padding:44px 36px 36px;box-shadow:var(--shadow-md);position:relative;overflow:hidden;}
.build-wrap::before{content:'';position:absolute;top:-80px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(37,99,235,.1),transparent 65%);pointer-events:none;}
.loop{position:relative;z-index:1;}
.loop-stage{font-size:.72rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted);display:flex;align-items:center;gap:12px;margin-bottom:26px;}
.loop-stage::after{content:'';flex:1;height:1px;background:var(--border-light);}
.loop-lane{display:flex;align-items:flex-start;justify-content:center;flex-wrap:wrap;gap:14px;}
.node{display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px;width:152px;flex:none;}
.tile{width:70px;height:70px;border-radius:20px;display:grid;place-items:center;position:relative;flex:none;background:var(--white);border:1.5px solid var(--border-light);color:var(--navy);box-shadow:var(--shadow-sm);transition:transform .45s cubic-bezier(.2,.7,.3,1),box-shadow .45s,background .45s,color .45s,border-color .45s;}
.tile svg{width:28px;height:28px;}
.tile.core{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 14px 28px -12px rgba(37,99,235,.9);}
.tile.is-on{background:var(--accent);color:#fff;border-color:var(--accent);transform:scale(1.07);box-shadow:0 0 0 9px rgba(37,99,235,.1),0 16px 30px -12px rgba(37,99,235,.6);}
.tile .check{position:absolute;right:-6px;bottom:-6px;width:24px;height:24px;border-radius:50%;background:var(--green);color:#fff;display:grid;place-items:center;transform:scale(0);transition:transform .4s cubic-bezier(.2,1.4,.4,1);box-shadow:0 4px 10px -2px rgba(22,163,74,.6);}
.tile .check svg{width:13px;height:13px;}
.node.done .check{transform:scale(1);}
.node h4{font-family:'Playfair Display',serif;font-weight:600;font-size:1rem;color:var(--navy-dark);margin:0;line-height:1.25;}
.node p{font-size:.78rem;color:var(--text-muted);margin:0;line-height:1.4;font-weight:300;}
.conn{position:relative;width:46px;height:2px;background:var(--border-light);border-radius:2px;flex:none;margin-top:34px;overflow:hidden;}
.conn::after{content:'';position:absolute;inset:0;width:42%;border-radius:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);transform:translateX(-130%);opacity:0;}
.conn.flow::after{animation:flow 1s linear infinite;opacity:1;}
@keyframes flow{from{transform:translateX(-130%);}to{transform:translateX(330%);}}
.outs{display:flex;flex-direction:column;gap:10px;width:236px;flex:none;}
.chip{display:flex;align-items:center;gap:11px;border-radius:13px;padding:11px 14px;border:1.5px solid var(--border-light);background:var(--white);box-shadow:var(--shadow-sm);transition:.4s;}
.chip .badge{width:32px;height:32px;border-radius:9px;flex:none;display:grid;place-items:center;}
.chip .badge svg{width:16px;height:16px;}
.chip h5{margin:0;font-size:.85rem;font-weight:600;color:var(--navy-dark);}
.chip small{display:block;font-size:.72rem;color:var(--text-muted);font-weight:300;}
.chip.auto .badge{background:var(--green-soft);color:var(--green);}
.chip.auto.hit{border-color:var(--green);box-shadow:0 0 0 2px var(--green-soft),var(--shadow-sm);}
.chip.pend{border-style:dashed;}
.chip.pend .badge{background:var(--navy-pale);color:var(--text-muted);}
.chip.pend.hit{border-color:var(--text-muted);box-shadow:0 0 0 2px var(--navy-pale),var(--shadow-sm);}
.chip.human .badge{background:var(--amber-soft);color:var(--amber);}
.chip.human.hit{border-color:var(--amber);box-shadow:0 0 0 2px var(--amber-soft),var(--shadow-sm);}
.tallies{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:34px;}
.tally{background:var(--off-white);border:1px solid var(--border-light);border-radius:14px;padding:18px 20px;}
.tally .tn{font-family:'Playfair Display',serif;font-weight:600;font-size:1.9rem;color:var(--navy-dark);line-height:1;}
.tally.auto .tn{color:var(--green);}
.tally.human .tn{color:var(--amber);}
.tally .tl{margin-top:6px;font-size:.76rem;color:var(--text-muted);font-weight:300;}
.gate{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-top:28px;background:repeating-linear-gradient(135deg,rgba(27,42,74,.03),rgba(27,42,74,.03) 8px,rgba(37,99,235,.05) 8px,rgba(37,99,235,.05) 16px);border:1.5px dashed rgba(37,99,235,.45);border-radius:14px;padding:16px 18px;}
.gate .lock{width:36px;height:36px;border-radius:10px;flex:none;display:grid;place-items:center;background:rgba(37,99,235,.1);color:var(--accent);}
.gate .lock svg{width:18px;height:18px;}
.gate strong{display:block;font-size:.92rem;color:var(--navy-dark);font-family:'Playfair Display',serif;font-weight:600;}
.gate small{display:block;font-size:.82rem;color:var(--text-body);font-weight:300;margin-top:2px;}
.gate a{margin-left:auto;font-size:.88rem;font-weight:500;color:var(--accent);text-decoration:none;white-space:nowrap;}
.gate a:hover{color:var(--accent-dark);}

/* ─── ACHIEVEMENTS ─── */
.ach-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.ach{background:var(--white);border:1px solid var(--border-light);border-radius:20px;border-left:4px solid var(--accent);padding:30px 28px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;}
.ach.amber{border-left-color:var(--amber);}
.ach.flag{grid-column:1/-1;border-left-width:5px;background:linear-gradient(150deg,var(--navy) 0%,var(--navy-mid) 100%);border-color:transparent;box-shadow:var(--shadow-md);position:relative;overflow:hidden;}
.ach.flag::before{content:'';position:absolute;top:-60px;right:-40px;width:240px;height:240px;background:radial-gradient(circle,rgba(37,99,235,.22),transparent 65%);pointer-events:none;}
.ach-top{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px;position:relative;z-index:1;}
.pill{display:inline-flex;align-items:center;gap:7px;font-size:.74rem;font-weight:500;padding:5px 13px;border-radius:100px;border:1px solid var(--border-light);background:var(--navy-pale);color:var(--navy);}
.pill i{width:7px;height:7px;border-radius:50%;background:var(--accent);}
.pill.amber{background:var(--amber-soft);color:var(--amber);border-color:rgba(217,119,6,.25);}
.pill.amber i{background:var(--amber);}
.ach.flag .pill{background:rgba(255,255,255,.12);color:#fff;border-color:rgba(255,255,255,.2);}
.ach.flag .pill i{background:var(--accent-soft);}
.flag-chip{font-size:.66rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-soft);background:rgba(37,99,235,.2);padding:5px 11px;border-radius:6px;}
.ach h3{font-family:'Playfair Display',serif;font-weight:600;color:var(--navy-dark);line-height:1.25;font-size:1.1rem;margin-bottom:10px;position:relative;z-index:1;}
.ach.flag h3{color:#fff;font-size:clamp(1.3rem,2.5vw,1.8rem);}
.ach-metrics{display:flex;gap:28px;flex-wrap:wrap;margin:6px 0 16px;position:relative;z-index:1;}
.am-v{font-family:'Playfair Display',serif;font-weight:600;font-size:1.7rem;color:var(--accent);letter-spacing:-.02em;line-height:1;}
.ach.flag .am-v{color:var(--accent-soft);}
.am-l{font-size:.74rem;color:var(--text-muted);margin-top:6px;}
.ach.flag .am-l{color:rgba(255,255,255,.6);}
.ach p{font-size:.9rem;color:var(--text-body);line-height:1.7;font-weight:300;flex:1;position:relative;z-index:1;}
.ach.flag p{color:rgba(255,255,255,.72);}
.why{margin-top:18px;padding-top:14px;border-top:1px dashed var(--border-light);font-size:.82rem;color:var(--text-body);line-height:1.55;font-weight:300;position:relative;z-index:1;}
.ach.flag .why{border-top-color:rgba(255,255,255,.18);color:rgba(255,255,255,.7);}
.why b{color:var(--navy-dark);font-weight:600;}
.ach.flag .why b{color:#fff;}
.ach-link{display:inline-flex;align-items:center;gap:6px;margin-top:18px;font-size:.85rem;font-weight:500;color:var(--accent-soft);text-decoration:none;align-self:flex-start;position:relative;z-index:1;border-bottom:1.5px solid rgba(147,197,253,.3);padding-bottom:2px;}
.ach-link:hover{border-color:var(--accent-soft);}
.ach-link svg{transition:transform .2s;}
.ach-link:hover svg{transform:translate(2px,-2px);}

/* ─── TIMELINE ─── */
.timeline{display:flex;flex-direction:column;max-width:720px;}
.tstep{display:grid;grid-template-columns:48px 1fr;gap:22px;}
.tnum-col{display:flex;flex-direction:column;align-items:center;}
.tnum{width:48px;height:48px;border-radius:14px;flex:none;background:var(--navy-dark);color:#fff;display:grid;place-items:center;font-family:'Playfair Display',serif;font-weight:600;font-size:1.1rem;}
.tline{width:2px;flex:1;background:var(--border-light);margin:8px 0;min-height:20px;}
.tstep:last-child .tline{display:none;}
.tbody{padding-bottom:32px;}
.tstep:last-child .tbody{padding-bottom:0;}
.tyear{font-size:.86rem;font-weight:600;color:var(--accent);letter-spacing:.02em;}
.trole{font-family:'Playfair Display',serif;font-weight:600;color:var(--navy-dark);font-size:1.15rem;margin:3px 0 4px;}
.tco{font-size:.9rem;color:var(--text-muted);font-weight:300;}

/* ─── HOW I THINK ─── */
.think{max-width:760px;}
.think .quote{font-family:'Playfair Display',serif;font-weight:600;color:var(--white);font-size:clamp(1.5rem,3.2vw,2.3rem);line-height:1.3;letter-spacing:-.01em;}
.think .quote em{font-style:italic;color:var(--accent-soft);}
.think .sig{margin-top:24px;font-size:1rem;color:rgba(255,255,255,.62);line-height:1.75;font-weight:300;}

/* ─── STACK ─── */
.stack-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;align-items:start;}
.stack-col{background:var(--white);border:1px solid var(--border-light);border-radius:20px;padding:28px 24px;box-shadow:var(--shadow-sm);transition:transform .25s,box-shadow .25s,border-color .25s;height:100%;}
.stack-col:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:rgba(37,99,235,.3);}
.stack-ic{width:50px;height:50px;border-radius:15px;flex:none;display:grid;place-items:center;background:linear-gradient(150deg,var(--navy) 0%,var(--navy-mid) 100%);color:#fff;box-shadow:0 10px 22px -10px rgba(27,42,74,.7);margin-bottom:18px;position:relative;overflow:hidden;}
.stack-ic::after{content:'';position:absolute;top:-14px;right:-14px;width:46px;height:46px;background:radial-gradient(circle,rgba(147,197,253,.4),transparent 65%);}
.stack-ic svg{width:25px;height:25px;position:relative;z-index:1;}
.stack-col h4{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;letter-spacing:0;text-transform:none;color:var(--navy-dark);margin-bottom:18px;}
.stack-wrap{display:flex;flex-wrap:wrap;gap:8px;}
.skill{background:var(--off-white);border:1px solid var(--border-light);color:var(--text-body);font-size:.83rem;font-weight:500;padding:7px 15px;border-radius:100px;transition:all .2s;}
.skill:hover{background:var(--navy);color:#fff;border-color:var(--navy);transform:translateY(-1px);}

/* ─── CONTACT ─── */
.contact{background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy-mid) 100%);padding:100px 0;position:relative;overflow:hidden;}
.contact::before{content:'';position:absolute;top:-15%;right:-5%;width:55vw;max-width:680px;height:80%;background:radial-gradient(ellipse,rgba(37,99,235,.16),transparent 65%);pointer-events:none;}
.contact-inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;}
.contact .section-label{color:var(--accent-soft);}
.contact h2{font-family:'Playfair Display',serif;font-weight:600;letter-spacing:-.02em;font-size:clamp(1.9rem,3.6vw,2.7rem);line-height:1.15;color:#fff;margin:14px 0 16px;}
.contact .lede{color:rgba(255,255,255,.65);font-size:1rem;line-height:1.7;font-weight:300;max-width:440px;}
.contact-cards{margin-top:30px;display:flex;flex-direction:column;gap:12px;}
.cc{display:flex;align-items:center;gap:14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:16px 18px;text-decoration:none;transition:all .2s;}
.cc:hover{background:rgba(255,255,255,.1);border-color:rgba(37,99,235,.4);transform:translateY(-1px);}
.cc-ic{width:42px;height:42px;border-radius:11px;flex:none;display:grid;place-items:center;background:var(--accent);color:#fff;}
.cc-ic svg{width:20px;height:20px;}
.cc-t{font-family:'Playfair Display',serif;font-weight:600;color:#fff;font-size:.98rem;display:block;}
.cc-s{font-size:.8rem;color:rgba(255,255,255,.55);}
.cc-arr{margin-left:auto;color:rgba(255,255,255,.45);}
.form-card{background:var(--white);border-radius:22px;padding:36px 32px;box-shadow:var(--shadow-lg);}
.fh{font-family:'Playfair Display',serif;font-weight:600;color:var(--navy-dark);font-size:1.2rem;margin-bottom:6px;}
.fs{font-size:.88rem;color:var(--text-muted);font-weight:300;margin-bottom:24px;}
.cf-field{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.cf-field label{font-size:.78rem;font-weight:500;color:var(--navy-dark);letter-spacing:.02em;}
.cf-field input,.cf-field textarea{width:100%;padding:13px 15px;background:var(--off-white);border:1px solid var(--border-light);border-radius:12px;color:var(--text-dark);font-family:'DM Sans',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s,background .2s,box-shadow .2s;resize:vertical;}
.cf-field input::placeholder,.cf-field textarea::placeholder{color:var(--text-muted);}
.cf-field input:focus,.cf-field textarea:focus{border-color:var(--accent);background:#fff;box-shadow:0 0 0 3px rgba(37,99,235,.12);}
.cf-field input.err,.cf-field textarea.err{border-color:#DC2626;}
.cf-submit{width:100%;justify-content:center;margin-top:6px;padding:15px;font-size:1rem;}
.cf-spinner{animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.cf-success{margin-top:14px;font-size:.9rem;color:var(--green);font-weight:500;display:none;}
.cf-error{margin-top:14px;font-size:.86rem;color:#DC2626;display:none;}
.cf-error a{color:#DC2626;font-weight:600;}

/* ─── FOOTER ─── */
footer{background:var(--navy-dark);border-top:1px solid rgba(255,255,255,.07);padding:30px 0;}
.foot-inner{max-width:1140px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.foot-logo{font-family:'Playfair Display',serif;font-size:.98rem;color:rgba(255,255,255,.55);text-decoration:none;}
